{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "",
    "ExpireMinutes": 15,
    "Issuer": "",
    "Audience": "",
    "CookieName":"JwtToken"
  },
  "Yarp":{
    "Routes":{
      "UserService":{
        "ClusterId": "userscluster",
        "Match": {"Path": "/users/{**catch-all}"},
        "Transforms":[
          {"PathRemovePrefix": "/users" }
        ]
      },
      "ChatService":{
        "ClusterId": "chatcluster",
        "Match": {"Path": "/ch/{**catch-all}"},
        "Transforms":[
          {"PathRemovePrefix": "/ch" }
        ]
      },
      "FacilityService":{
        "ClusterId": "facilitycluster",
        "Match": {"Path": "/fac/{**catch-all}"},
        "Transforms":[
          {"PathRemovePrefix": "/fac" }
        ]
      },
      "SubscriptionService":{
        "ClusterId": "subscriptioncluster",
        "Match": {"Path": "/sub/{**catch-all}"},
        "Transforms":[
          {"PathRemovePrefix": "/sub" }
        ]
      }
    },
    "Clusters":{
      "userscluster":{
        "Destinations":{
          "users1":{"Address":"http://${USERS_HOST}:${USERS_PORT}/"}
        }
      },
      "chatcluster":{
        "Destinations":{
          "chats1":{"Address":"http://${CHAT_HOST}:${CHAT_PORT}/"}
        }
      },
      "facilitycluster":{
        "Destinations":{
          "facilities1":{"Address":"http://${FACILITY_HOST}:${FACILITY_PORT}/"}
        }
      },
      "subscriptioncluster":{
        "Destinations":{
          "subscriptions1":{"Address":"http://${SUBSCRIPTION_HOST}:${SUBSCRIPTION_PORT}/"}
        }
      }
      
    }
  }
}
